{
    "configurations": [
        {
            "name": "Win32",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "HANDMADE_DEBUG",
                "HANDMADE_INTERNAL",
                "HANDMADE_WIN32"
            ],
            "windowsSdkVersion": "10.0.26100.0",
            "compilerPath": "cl.exe",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "windows-msvc-x64",
            "recursiveIncludes": {
                "reduce": "${default}"
            }
        },
        {
            "name": "Linux",
            "includePath": [
                "${workspaceFolder}/**"
            ],
            "defines": [
                "HANDMADE_DEBUG",
                "HANDMADE_INTERNAL",
                "HANDMADE_LINUX"
            ],
            "compilerPath": "/opt/llvm-22.1.0/bin/clang++",
            "cStandard": "c17",
            "cppStandard": "c++20",
            "intelliSenseMode": "linux-clang-x64"
        }
    ],
    "version": 4
}
